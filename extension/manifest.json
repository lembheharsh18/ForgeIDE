{
  "manifest_version": 3,
  "name": "Forge IDE for Codeforces",
  "version": "0.1.0",
  "description": "Parse Codeforces problems and submit solutions directly from Forge IDE.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://codeforces.com/*"],
  "content_scripts": [
    {
      "matches": [
        "https://codeforces.com/problemset/problem/*",
        "https://codeforces.com/contest/*/problem/*"
      ],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Forge IDE"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
