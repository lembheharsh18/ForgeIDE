# ──────────────────────────────────────────────
# FORGE IDE — Environment Variables
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────

# ── Database ──────────────────────────────────
DATABASE_URL="postgresql://forge:forge_secret@localhost:5432/forge_ide"

# ── Redis ─────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Authentication ────────────────────────────
JWT_SECRET="change-this-in-production-min-32-chars"
JWT_REFRESH_SECRET="change-this-too-min-32-chars"
NEXTAUTH_SECRET=""
NEXTAUTH_URL="https://your-domain.com"

# ── Google OAuth ──────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Code Execution (Piston API) ──────────────
PISTON_URL="https://emkc.org/api/v2/piston"

# ── Codeforces API (per-user, optional) ──────
CF_API_KEY=""
CF_API_SECRET=""

# ── Frontend URLs ─────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_WS_URL="ws://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Server ────────────────────────────────────
PORT=4000
NODE_ENV=development
