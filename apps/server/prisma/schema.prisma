// ──────────────────────────────────────────────
// FORGE IDE — Prisma Schema
// ──────────────────────────────────────────────

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ── Enums ────────────────────────────────────────

enum Role {
  MEMBER
  ADMIN
}

enum Platform {
  CODEFORCES
  ATCODER
  LEETCODE
  CUSTOM
}

enum ContestType {
  NORMAL
  REVERSE_CODING
}

// ── User ─────────────────────────────────────────

model User {
  id                String            @id @default(cuid())
  username          String            @unique
  email             String            @unique
  passwordHash      String?
  role              Role              @default(MEMBER)
  codeforcesHandle  String?
  codechefHandle    String?
  leetcodeUsername  String?
  handlesVerified   Boolean           @default(false)
  avatarUrl         String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  submissions       Submission[]
  solvedProblems    Problem[]         @relation("SolvedBy")
  leaderboard       LeaderboardEntry?
  platformProfile   PlatformProfileCache?
  contestParticipations Contest[]     @relation("Participants")
  chatMessages      ChatMessage[]
}

// ── Problem ──────────────────────────────────────

model Problem {
  id          String       @id @default(cuid())
  title       String
  platform    Platform
  difficulty  String
  tags        String[]
  link        String?
  statement   String?      @db.Text
  inputSpec   String?      @db.Text
  outputSpec  String?      @db.Text
  noteSection String?      @db.Text
  timeLimit   Int?
  memoryLimit Int?
  cfContestId String?
  cfIndex     String?
  testCases   Json?
  referenceSolution String?  @db.Text
  referenceLang     String?
  addedById   String
  createdAt   DateTime     @default(now())
  solvedBy    User[]       @relation("SolvedBy")
  submissions Submission[]
  contests    Contest[]    @relation("ContestProblems")
}

// ── Submission ───────────────────────────────────

model Submission {
  id         String   @id @default(cuid())
  userId     String
  problemId  String
  language   String
  code       String   @db.Text
  verdict    String   @default("PENDING")
  timeMs     Int?
  memoryKb   Int?
  errorMsg   String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem    Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
}

// ── Contest ──────────────────────────────────────

model Contest {
  id           String      @id @default(cuid())
  name         String
  type         ContestType @default(NORMAL)
  platform     Platform
  startTime    DateTime
  endTime      DateTime
  link         String
  description  String?
  participants User[]      @relation("Participants")
  problems     Problem[]   @relation("ContestProblems")
  createdAt    DateTime    @default(now())
}

// ── Leaderboard ──────────────────────────────────

model LeaderboardEntry {
  id          String   @id @default(cuid())
  userId      String   @unique
  score       Int      @default(0)
  solvedCount Int      @default(0)
  rank        Int      @default(0)
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Reverse Coding ───────────────────────────────

model ReverseQueryLog {
  id          String   @id @default(cuid())
  userId      String
  problemId   String
  input       String   @db.Text
  output      String   @db.Text
  createdAt   DateTime @default(now())
}

// ── Platform Profiles ────────────────────────────

model PlatformProfileCache {
  id          String   @id @default(cuid())
  userId      String   @unique
  cfRating    Int?
  cfRank      String?
  lcRating    Int?
  ccRating    Int?
  ccStars     Int?
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Chat (Community) ─────────────────────────────

model ChatRoom {
  id          String        @id @default(cuid())
  name        String        @unique
  description String?
  whiteboardData Json?
  createdAt   DateTime      @default(now())
  messages    ChatMessage[]
}

model ChatMessage {
  id          String    @id @default(cuid())
  roomId      String
  userId      String
  content     String    @db.Text
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  
  room        ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

